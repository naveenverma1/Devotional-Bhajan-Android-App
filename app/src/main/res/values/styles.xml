<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorSurface</item>
    </style>

    <!--
        Splash variant: window background is the brand image so the user
        sees it from the instant they tap the app icon (no white flash
        before MainActivity inflates its layout).
    -->
    <style name="AppTheme.Splash" parent="AppTheme">
        <item name="android:windowBackground">@mipmap/splash</item>
    </style>
</resources>
