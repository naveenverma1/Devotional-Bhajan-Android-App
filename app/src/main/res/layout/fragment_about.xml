<?xml version="1.0" encoding="utf-8"?>
<!--
    About screen. WebView fills the screen above a bottom button row:
    Rate (opens Play listing) + Share (share intent) + Privacy (loads
    privacy_policy.html in the same WebView).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".about">

    <WebView
        android:id="@+id/aboutweb"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/about_rate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/about_rate" />

        <Button
            android:id="@+id/about_share"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="@string/about_share" />

        <Button
            android:id="@+id/about_privacy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/about_privacy" />

    </LinearLayout>

</LinearLayout>
