<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable top-right A-/A+ font-size control bar. Include in any reader
    fragment that displays HTML asset content via a WebView. The host
    Fragment wires the IDs via ReaderUi.wireReader(...).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@color/colorSurface"
    android:gravity="end|center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp">

    <Button
        android:id="@+id/btn_font_smaller"
        android:layout_width="44dp"
        android:layout_height="40dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="@string/content_desc_font_decrease"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/font_size_small"
        android:textColor="@color/colorOnSurface"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_font_larger"
        android:layout_width="44dp"
        android:layout_height="40dp"
        android:contentDescription="@string/content_desc_font_increase"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/font_size_large"
        android:textColor="@color/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
